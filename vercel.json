{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/quote",
      "dest": "/api/quote.py"
    },
    {
      "src": "/api/history",
      "dest": "/api/history.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/public/static/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
