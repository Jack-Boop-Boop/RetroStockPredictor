# =============================================================================
# RetroStockPredictor - Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Required ---

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/stockpredictor

# JWT secret for auth tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=change-me-to-a-random-secret

# --- Optional: Redis (Upstash) for caching + rate limiting ---
REDIS_URL=
REDIS_TOKEN=

# --- Optional: Market data providers ---
NEWS_API_KEY=
ALPHA_VANTAGE_KEY=

# --- Optional: Robinhood (live trading only) ---
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_TOTP=

# --- App settings ---
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
